# ============================================================
# AI Employee Gold Tier — Environment Variables
# ============================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# Gmail (SKILL-007: Gmail Watcher + SKILL-009: Email Sender)
# App Password: Google Account > Security > 2FA > App Passwords
# ------------------------------------------------------------
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_CHECK_INTERVAL=300

# ------------------------------------------------------------
# Email Sender MCP (SKILL-009)
# true = log only, no emails sent (safe for testing)
# ------------------------------------------------------------
EMAIL_DRY_RUN=false

# ------------------------------------------------------------
# LinkedIn Poster MCP (SKILL-010)
# true = simulate post, do not publish
# ------------------------------------------------------------
LINKEDIN_DRY_RUN=true

# ------------------------------------------------------------
# Meta Social MCP (Gold Tier)
# Facebook Page + Instagram Business account
# true = simulate posts, do not publish
#
# Permissions needed:
#   pages_manage_posts, instagram_basic, instagram_content_publish
# ------------------------------------------------------------
META_DRY_RUN=true
FB_PAGE_ID=your_facebook_page_id
FB_ACCESS_TOKEN=your_facebook_page_access_token
IG_USER_ID=your_instagram_business_user_id
IG_ACCESS_TOKEN=your_instagram_access_token

# ------------------------------------------------------------
# Twitter/X Poster MCP (Gold Tier)
# true = simulate tweets, do not publish
#
# Credentials from: developer.twitter.com
# App must have "Read and Write" permissions
# ------------------------------------------------------------
TWITTER_DRY_RUN=true
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# ------------------------------------------------------------
# Odoo Accounting MCP (Gold Tier)
# Self-hosted Odoo Community (v16+)
# ------------------------------------------------------------
ODOO_URL=http://localhost:8069
ODOO_DB=your_odoo_database_name
ODOO_USERNAME=admin
ODOO_PASSWORD=your_odoo_password
# true = simulate all Odoo actions, nothing is written to Odoo
ODOO_DRY_RUN=false
